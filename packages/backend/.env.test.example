# Node
TZ=UTC
PORT=3333
HOST=localhost
NODE_ENV=test

# App
LOG_LEVEL=error
APP_KEY=
APP_URL=http://${HOST}:${PORT}

# CORS (configure allowed origins for API access)
# In tests, cors is disabled
CORS_ORIGIN=

# Rate Limiter
LIMITER_STORE=memory

# Redis
REDIS_CONNECTION=test
REDIS_HOST=127.0.0.1
REDIS_PORT=8002
REDIS_PASSWORD=

# Database
DB_HOST=127.0.0.1
DB_PORT=8001
DB_USER=adonisjs
DB_PASSWORD=
DB_DATABASE=app-test