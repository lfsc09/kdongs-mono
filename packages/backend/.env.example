# Node
TZ=UTC
PORT=3333
HOST=localhost
NODE_ENV=development

# App
LOG_LEVEL=info
APP_KEY=
APP_URL=http://${HOST}:${PORT}

# CORS (configure allowed origins for API access)
# In development, allow all origins (leave it empty)
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Rate Limiter
LIMITER_STORE=redis

# Redis
REDIS_CONNECTION=main
REDIS_HOST=127.0.0.1
REDIS_PORT=8002
REDIS_PASSWORD=

# Database
DB_HOST=127.0.0.1
DB_PORT=8001
DB_USER=adonisjs
DB_PASSWORD=
DB_DATABASE=app