{
  "name": "kdongs-mono",
  "version": "4.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "prepare": "husky install",
    "dev:setup": "./scripts/local.bootstrap.sh",
    "dev:docker-db-up": "docker compose -f docker/compose.local.yaml --profile db-only up --build --detach",
    "dev:docker-db-down": "docker compose -f docker/compose.local.yaml --profile db-only down --volumes --rmi all",
    "dev:docker-full-up": "docker compose -f docker/compose.local.yaml --profile full up --build --detach",
    "dev:docker-full-down": "docker compose -f docker/compose.local.yaml --profile full down --volumes --rmi all",
    "dev:mono": "mprocs \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:mono:dependencies": "npx npm-check-updates --workspaces",
    "dev:mono:dependencies:update": "npx npm-check-updates -u --workspaces",
    "dev:mono:dependencies:upgrade": "npm install",
    "dev:domain:build": "npm run build --workspace @kdongs-mono/domain",
    "dev:domain:format": "npm run biome:check --workspace @kdongs-mono/domain",
    "dev:domain:dependencies": "npx npm-check-updates --workspace @kdongs-mono/domain --no-root",
    "dev:domain:dependencies:update": "npx npm-check-updates -u --workspace @kdongs-mono/domain --no-root",
    "dev:frontend": "npm start --workspace @kdongs-mono/frontend",
    "dev:frontend:dependencies": "npx npm-check-updates --workspace @kdongs-mono/frontend --no-root",
    "dev:frontend:dependencies:update": "npx npm-check-updates -u --workspace @kdongs-mono/frontend --no-root",
    "dev:frontend:format": "npm run format --workspace @kdongs-mono/frontend",
    "dev:backend": "npm run dev --workspace @kdongs-mono/backend",
    "dev:backend:dependencies": "npx npm-check-updates --workspace @kdongs-mono/backend --no-root",
    "dev:backend:dependencies:update": "npx npm-check-updates -u --workspace @kdongs-mono/backend --no-root",
    "dev:backend:schema-generate": "npm run schema:generate --workspace @kdongs-mono/backend",
    "dev:backend:migrate-fresh": "npm run migration:fresh --workspace @kdongs-mono/backend",
    "dev:backend:migrate-with-seed": "npm run migration:fresh:seed --workspace @kdongs-mono/backend",
    "dev:backend:format": "npm run biome:check --workspace @kdongs-mono/backend",
    "test:frontend": "npm run test --workspace @kdongs-mono/frontend",
    "test:backend": "npm run test --workspace @kdongs-mono/backend"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lfsc09/kdongs-mono.git"
  },
  "keywords": [],
  "author": "lfsc09@gmail.com",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/lfsc09/kdongs-mono/issues"
  },
  "homepage": "https://github.com/lfsc09/kdongs-mono#readme",
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "mprocs": "^0.8.3",
    "npm-check-updates": "^19.6.3"
  },
  "lint-staged": {
    "packages/frontend/src/**/*.{ts,js,json,css,scss,html,md}": [
      "npm run dev:frontend:format"
    ],
    "packages/backend/**/*.{ts,js,json,env,md}": [
      "npm run dev:backend:format"
    ],
    "packages/domain/**/*.{ts,js,json,md}": [
      "npm run dev:domain:format"
    ]
  },
  "workspaces": [
    "packages/backend",
    "packages/frontend",
    "packages/domain"
  ]
}
